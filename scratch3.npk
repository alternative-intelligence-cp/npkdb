use "../../src/util/mem_primitives.npk".*;

func:main = int32(int32:argc, any->:argv) {
    int64:buf = npk_core_alloc(10i64);
    drop(npk_mem_write_byte(buf, 0i64, 48i64)); // '0'
    
    int8->:buffer = @cast_unchecked<int8->>(buf);
    int64:ptr = @cast_unchecked<int64>(buffer);
    int64:val = npk_mem_read_byte(ptr, 0i64);
    
    int8:c = @cast_unchecked<int8>(val);
    
    exit(0i32);
};

func:failsafe = int32(tbb32:err) {
    exit(1i32);
};
