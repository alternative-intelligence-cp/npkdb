use "../../src/util/error_codes.npk".*;
use "../../src/util/mem_primitives.npk".*;
use "../../src/document/json_types.npk".*;
use "../../src/document/json_parser.npk".*;

extern "C" {
    func:_exit = void(int32:code);
}

pub func:proc_exit = NIL(int32:code) {
    _exit(code);
    pass(NIL);
};

func:main = int32(int32:argc, wild any->:argv) {
    // 1. Test parse_i64
    int64:buf1 = npk_core_alloc(32i64);
    drop(npk_mem_write_string(buf1, "   -12345  "));
    
    ParserState:state1 = ParserState {
        buf: buf1,
        length: 11i64,
        pos: 0i64,
        depth: 0i64
    };
    
    drop(skip_whitespace(@state1));
    int64:num = _!parse_i64(@state1);
    
    if (num != -12345i64) { exit(11i32); }
    if (state1.pos != 9i64) { exit(12i32); }
    
    // 2. Test parse_string
    int64:buf2 = npk_core_alloc(32i64);
    drop(npk_mem_write_string(buf2, "  \"hello world\"  "));
    
    ParserState:state2 = ParserState {
        buf: buf2,
        length: 17i64,
        pos: 0i64,
        depth: 0i64
    };
    
    drop(skip_whitespace(@state2));
    NpkJsonStr:s = _!parse_string(@state2);
    
    if (s.length != 11u32) { exit(21i32); }
    if (state2.pos != 15i64) { exit(22i32); }
    
    // Verify first char 'h'
    int64:first_char = npk_mem_read_byte(s.data, 0i64);
    if (first_char != 104i64) {
        exit((first_char & 255i64) => int32);
    } // 'h' is 104
    
    // 3. Test parse_array with floats
    string:json_str = "[12.34, -5.6, 7.8]";
    NpkJsonVal:v = _!parse_json(json_str);
    if (v.type != JSON_ARR) { exit(31i32); }
    
    int64:arr_ptr = v.payload;
    int32:arr_count = npk_mem_read_int32(arr_ptr, 0i64);
    if (arr_count != 3i32) { exit(32i32); } // count == 3
    
    int64:handles_ptr = npk_mem_read_int64(arr_ptr, 8i64);
    
    // Check first value (12.34)
    int64:v1_ptr = npk_mem_read_int64(handles_ptr, 0i64);
    int8:v1_type = (npk_mem_read_byte(v1_ptr, 0i64)) => int8;
    
    if (v1_type != JSON_NUM_F64) { exit(33i32); }
    int64:v1_bits = npk_mem_read_int64(v1_ptr, 8i64);
    flt64:v1_f = <-(@v1_bits => flt64->);
    // 12.34
    
    // 4. Test parse_object
    string:obj_str = "{\"status\": \"active\"}";
    NpkJsonVal:obj_v = _!parse_json(obj_str);
    if (obj_v.type != JSON_OBJ) { exit(41i32); }
    
    int64:obj_ptr = obj_v.payload;
    int32:obj_count = npk_mem_read_int32(obj_ptr, 0i64);
    if (obj_count != 1i32) { exit(42i32); }

    println("JSON parser tests passed!");
    exit(0i32);
};

func:failsafe = int32(tbb32:err) {
    exit(1i32);
};
