use "../../../nitpick-packages/packages/nitpick-server/src/nitpick_server.npk".*;
use "controllers_mock.npk".*;
use "router_mock.npk".*;

use "mock_send_typed.npk".*;

extern "C" {
    func:npk_gc_init = int32(int64:nursery_size, int64:heap_size);
}

use "../../src/engine/catalog.npk".*;
use "../../src/concurrency/ebr.npk".*;
use "../../src/index/art.npk".*;

func:main = int32(int32:argc, wild any->:argv) {
    drop(npk_gc_init(10485760i64, 104857600i64));
    drop(ebr_init());
    drop(art_init());
    drop(catalog_init());
    // 1. Test POST /collections with malformed JSON
    ServerRequest:r1 = ServerRequest{
        method: "POST",
        path: "/collections",
        query: "",
        version: "HTTP/1.1",
        body: "{ malformed }",
        raw_req: "",
        headers_raw: "",
        body_ptr: string_to_cstr("{ malformed }"),
        body_len: 13i64,
        buf_addr: 0i64
    };
    drop(route_request(1i64, r1, 0i64));
    
    println("After route 1");
    // 2. Test POST /search with malformed JSON
    ServerRequest:r2 = ServerRequest{
        method: "POST",
        path: "/collections/dummy_col/search",
        query: "",
        version: "HTTP/1.1",
        body: "[1, 2, 3",
        raw_req: "",
        headers_raw: "",
        body_ptr: string_to_cstr("[1, 2, 3"),
        body_len: 8i64,
        buf_addr: 0i64
    };
    drop(route_request(2i64, r2, 0i64));
    
    println("HTTP Errors test passed!");
    exit(0i32);
};

func:failsafe = int32(tbb32:err) {
    exit(1i32);
};
