use "src/util/mem_primitives.npk".*;

extern func:npk_string_from_cstr_simple = string(int64:cstr);

pub func:failsafe = int32(tbb32:err) { exit(1); };

pub func:main = int32() {
    int64:buf = npk_core_alloc(6i64);
    
    drop(npk_mem_write_byte(buf, 0i64, 104i64)); // h
    drop(npk_mem_write_byte(buf, 1i64, 101i64)); // e
    drop(npk_mem_write_byte(buf, 2i64, 108i64)); // l
    drop(npk_mem_write_byte(buf, 3i64, 108i64)); // l
    drop(npk_mem_write_byte(buf, 4i64, 111i64)); // o
    drop(npk_mem_write_byte(buf, 5i64, 0i64));   // \0
    
    string:s = npk_string_from_cstr_simple(buf);
    
    println("Result string: " + s);
    
    drop(npk_core_dalloc(buf));
    
    exit(0);
};
